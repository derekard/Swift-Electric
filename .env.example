# Copy to .env.local for local dev:  cp .env.example .env.local
# On Render these are set in the dashboard (Blueprint marks them `sync: false`).

# --- Supabase (required) ---------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- App URLs --------------------------------------------------------------
# Production origin (used for OAuth redirects, email links). Must match the URL
# you add to Supabase → Auth → URL Configuration. Locally: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Apex used for <slug>.<domain> tenant subdomains, e.g. swiftelectric.ca
NEXT_PUBLIC_APP_DOMAIN=

# --- Cron ------------------------------------------------------------------
# Shared secret protecting /api/cron/invoice-reminders. On Render this is
# generated automatically; set any value locally to test the endpoint.
CRON_SECRET=

# --- Email reminders (Resend) — required for Net-15 reminders to send ------
RESEND_API_KEY=
EMAIL_FROM=

# --- Voice quote parsing (Anthropic) — optional ----------------------------
ANTHROPIC_API_KEY=

# --- Local dev only --------------------------------------------------------
# Force a tenant when there's no subdomain (e.g. on localhost). Prod uses the host.
DEV_TENANT_SLUG=
